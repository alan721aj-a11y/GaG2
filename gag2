local function popup(text)
	Notify.Text = text
	Notify.Visible = true
	Notify.TextTransparency = 1

	TweenService:Create(
		Notify,
		TweenInfo.new(.3),
		{TextTransparency = 0}
	):Play()

	task.wait(2)

	TweenService:Create(
		Notify,
		TweenInfo.new(.3),
		{TextTransparency = 1}
	):Play()

	task.wait(.3)
	Notify.Visible = false
end

